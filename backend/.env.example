# miniClaw Backend Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# LLM Configuration
# ============================================================================

# Choose LLM provider: openai, deepseek, qwen, ollama, claude, gemini, custom
LLM_PROVIDER=qwen

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek Configuration
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen (通义千问) Configuration - Default for testing
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_MODEL=qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Ollama (Local) Configuration
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5
# Note: Ollama doesn't require API key. Install from https://ollama.com
#       After installation, run: ollama pull qwen2.5

# Claude (Anthropic) Configuration - Using OpenAI-compatible mode
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
# CLAUDE_BASE_URL=https://api.anthropic.com

# Gemini (Google) Configuration
GEMINI_API_KEY=AIza-your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Custom OpenAI-compatible API
# CUSTOM_API_KEY=
# CUSTOM_MODEL=
# CUSTOM_BASE_URL=

# ============================================================================
# LangSmith Tracing (Optional)
# ============================================================================
# WARNING: Enabling tracing uploads API keys and conversation content to LangSmith
# LANGCHAIN_API_KEY=
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_PROJECT=miniclaw

# ============================================================================
# Memory System Configuration
# ============================================================================

# Enable/disable memory features
ENABLE_MEMORY_EXTRACTION=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_USER_PROFILE_LEARNING=true
ENABLE_LONG_TERM_MEMORY=true

# Memory extraction settings
MEMORY_EXTRACTION_INTERVAL=5
MEMORY_MIN_CONFIDENCE=0.6
MEMORY_MAX_CONVERSATIONS=100

# User profile settings
USER_PROFILE_UPDATE_INTERVAL=10

# Long-term memory settings
LONG_TERM_MEMORY_MAX_ITEMS=50
LONG_TERM_MEMORY_PRUNE_THRESHOLD=0.3

# ============================================================================
# Application Settings
# ============================================================================

# APP_NAME=miniClaw
# APP_VERSION=0.1.0
# DEBUG=false

# Server Configuration
# HOST=0.0.0.0
# PORT=8002
# CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000","http://127.0.0.1:3001"]

# ============================================================================
# File Paths
# ============================================================================

# BASE_DIR=.
# DATA_DIR=data
# KNOWLEDGE_BASE_DIR=data/knowledge_base
# SESSIONS_DIR=data/sessions
# SKILLS_DIR=data/skills
# VECTOR_STORE_DIR=data/vector_store
# WORKSPACE_DIR=workspace

# ============================================================================
# Tool Security
# ============================================================================

# TERMINAL_ROOT_DIR=.
# READ_FILE_ROOT_DIR=.

# Python REPL Configuration
# PYTHON_EXECUTION_MODE=standard  # safe, standard, free
# PYTHON_SAFE_TIMEOUT=60
# PYTHON_STANDARD_TIMEOUT=300
# PYTHON_FREE_TIMEOUT=1800

# ============================================================================
# HuggingFace Configuration (for China users)
# ============================================================================
# Configure HuggingFace Hub behavior and timeouts
# HF_HUB_DISABLE_TELEMETRY=1    # Disable telemetry uploads
# HF_HUB_OFFLINE=0               # Allow online mode (uses HF-Mirror)
# TRANSFORMERS_OFFLINE=0         # Allow online mode
# HF_HUB_DOWNLOAD_RETRY=2        # Max retries for downloads (reduces wait time)
# HF_HUB_DOWNLOAD_TIMEOUT=30     # Download timeout in seconds
#
# If downloads timeout, manually download:
# pip install huggingface_hub
# HF_ENDPOINT=https://hf-mirror.com huggingface-cli download sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 --local-dir backup/data/models

# ============================================================================
# Embedding Model Configuration
# ============================================================================
# Configure embedding model loading and warmup behavior
# EMBEDDING_WARMUP_ENABLED=true       # Enable startup warmup (preload model)
# EMBEDDING_WARMUP_TIMEOUT=60         # Warmup timeout in seconds
# EMBEDDING_HF_ENDPOINT=https://hf-mirror.com  # HuggingFace mirror URL
# EMBEDDING_HF_TIMEOUT=20             # Single download timeout (seconds)
# EMBEDDING_HF_RETRIES=2              # Download retry count

# ============================================================================
# RAG / Knowledge Base
# ============================================================================

# EMBEDDING_MODEL=text-embedding-ada-002
# VECTOR_STORE_TYPE=chroma
# HYBRID_SEARCH_ALPHA=0.5
# RETRIEVAL_TOP_K=5
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50
# MAX_FILE_SIZE=10485760  # 10MB
# ALLOWED_FILE_TYPES=['.txt', '.md', '.pdf', '.docx']
# EMBEDDING_FALLBACK=sentence-transformers

# ============================================================================
# Session Management
# ============================================================================

# SESSION_TIMEOUT=3600
# MAX_MESSAGE_HISTORY=100

# ============================================================================
# System Prompt
# ============================================================================

# MAX_PROMPT_LENGTH=20000
# TRUNCATION_MARKER=...[truncated]

# ============================================================================
# Reflection System
# ============================================================================
# ENABLE_AGENT_REFLECTION=true
# AGENT_REFLECTION_QUALITY_THRESHOLD=6.0
# EVALUATION_CACHE_ENABLED=true
# ENABLE_REFLECTION_LEARNING=true

# ============================================================================
# PERV Enhancement
# ============================================================================
# PERV_ROUTER_ENABLED=true
# PERV_ENABLE_POST_LEARNING=true
# PERV_ENABLE_PATTERN_RETRIEVAL=true
# PERV_ENABLE_STRATEGY_INJECTION=true
# PERV_ENABLE_SEMANTIC_HISTORY=true

# ============================================================================
# Meta Policy & TCA
# ============================================================================
# ENABLE_META_POLICY=false
# ENABLE_TCA=false

# ============================================================================
# RL Training
# ============================================================================
# ENABLE_RL_TRAINING=false
# RL_TARGET_UPDATE_FREQ=100
# RL_TAU=0.005
# RL_TRANSFORMER_LR=0.0001
# RL_MLP_LR=0.0003
# RL_KL_COEF=0.1
# RL_PROMPT_CONSISTENCY_COEF=0.05
# RL_BATCH_SIZE=32
# RL_GRADIENT_CLIP=1.0

# ============================================================================
# Neural Strategy
# ============================================================================
# ENABLE_NEURAL_STRATEGY=false
# NEURAL_STRATEGY_AUTO_TRANSITION=true

# ============================================================================
# Memory Retriever
# ============================================================================
# ENABLE_KG=false
# KG_STORE_BACKEND=memory
# SIMILARITY_THRESHOLD=0.7
# SIMILARITY_BLOCK_THRESHOLD=0.95
