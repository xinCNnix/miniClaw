# Environment Configuration for miniClaw
# Copy this file to .env and fill in your actual values

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=miniClaw
APP_VERSION=0.1.0
DEBUG=False

# ============================================================================
# Server Settings
# ============================================================================
HOST=0.0.0.0
PORT=8002

# ============================================================================
# LLM Configuration
# ============================================================================
# Select provider: openai, deepseek, qwen, ollama, claude, gemini, custom
LLM_PROVIDER=qwen

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen (通义千问)
QWEN_API_KEY=
QWEN_MODEL=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=

# Claude (Anthropic)
CLAUDE_API_KEY=
CLAUDE_MODEL=
CLAUDE_BASE_URL=https://api.anthropic.com

# Gemini (Google)
GEMINI_API_KEY=
GEMINI_MODEL=

# Custom OpenAI-compatible API
CUSTOM_API_KEY=
CUSTOM_MODEL=
CUSTOM_BASE_URL=

# ============================================================================
# LangSmith Tracing (Optional)
# ============================================================================
# WARNING: Enabling this uploads API keys and conversations to LangSmith
# Only enable for development/debugging, NEVER in production
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=False
LANGCHAIN_PROJECT=mini-openclaw

# ============================================================================
# File Paths
# ============================================================================
BASE_DIR=.
DATA_DIR=data
KNOWLEDGE_BASE_DIR=data/knowledge_base
SESSIONS_DIR=data/sessions
SKILLS_DIR=data/skills
VECTOR_STORE_DIR=data/vector_store
WORKSPACE_DIR=workspace

# ============================================================================
# Tool Security
# ============================================================================
TERMINAL_ROOT_DIR=.
READ_FILE_ROOT_DIR=.

# Additional allowed directories for Python REPL write operations
# Example: ALLOWED_WRITE_DIRS=["/tmp","/home/user/projects"]
ALLOWED_WRITE_DIRS=

# ============================================================================
# Tree of Thoughts Configuration
# ============================================================================
ENABLE_TOT=True
TOT_MAX_DEPTH=2
TOT_BRANCHING_FACTOR=3
TOT_QUALITY_THRESHOLD=6.0
TOT_AUTO_ENABLE_KEYWORDS=deep research,comprehensive analysis,detailed investigation

# ToT Tool Call Validation
TOT_ENABLE_TOOL_VALIDATION=True
TOT_MAX_TOOL_RETRIES=2

# ToT Smart Stopping
TOT_ENABLE_SMART_STOPPING=True
TOT_MIN_SUCCESSFUL_TOOLS=50
TOT_REDUNDANCY_WINDOW=15
TOT_SCORE_PLATEAU_THRESHOLD=0.3
TOT_ENABLE_LLM_EVALUATION=True
TOT_LLM_EVAL_INTERVAL=3
TOT_MAX_DEPTH_MULTIPLIER=2.0

# ToT Path Selection
TOT_ENABLE_BEAM_SEARCH=True
TOT_BEAM_WIDTH=3
TOT_ENABLE_BACKTRACKING=True
TOT_BACKTRACK_FAILURE_THRESHOLD=0.5
TOT_BACKTRACK_PLATEAU_THRESHOLD=0.3

# ToT Tool Result Cache
TOT_ENABLE_CACHE=True
TOT_CACHE_TTL=300

# ============================================================================
# Deep Research Configuration
# ============================================================================
ENABLE_DEEP_RESEARCH=True
RESEARCH_MODE=heuristic

# ============================================================================
# RAG / Knowledge Base
# ============================================================================
ENABLE_RAG=True
EMBEDDING_MODEL=text-embedding-ada-002
VECTOR_STORE_TYPE=chroma
HYBRID_SEARCH_ALPHA=0.5
RETRIEVAL_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_FILE_SIZE=1073741824
LARGE_FILE_THRESHOLD=104857600
EMBEDDING_FALLBACK=sentence-transformers

# Embedding Model Configuration
EMBEDDING_WARMUP_ENABLED=True
EMBEDDING_WARMUP_TIMEOUT=60
EMBEDDING_HF_ENDPOINT=https://hf-mirror.com
EMBEDDING_HF_TIMEOUT=20
EMBEDDING_HF_RETRIES=2

# ============================================================================
# Session Management
# ============================================================================
SESSION_TIMEOUT=3600
MAX_MESSAGE_HISTORY=100

# ============================================================================
# System Prompt
# ============================================================================
MAX_PROMPT_LENGTH=20000
TRUNCATION_MARKER=...[truncated]

# ============================================================================
# Agent Execution
# ============================================================================
MAX_TOOL_ROUNDS=60
ENABLE_SMART_STOPPING=True
SUFFICIENCY_EVALUATION_INTERVAL=5

# ============================================================================
# Performance Optimization
# ============================================================================
# Caching
ENABLE_SEMANTIC_SEARCH_CACHE=True
SEMANTIC_SEARCH_CACHE_TTL=300
ENABLE_CONTEXT_CACHE=True
CONTEXT_CACHE_SIZE=64
ENABLE_PROMPT_CACHE=True

# Parallel Tool Execution
ENABLE_PARALLEL_TOOL_EXECUTION=True
ENABLE_AUTO_FALLBACK=True
PARALLEL_TOOL_DEPENDENCY_DETECTION=True
MAX_CONCURRENT_TOOLS=5

# Streaming Response
ENABLE_STREAMING_RESPONSE=True
STREAMING_CHUNK_SIZE=512

# Prompt Compression
ENABLE_SMART_TRUNCATION=True
MAX_PROMPT_TOKENS=15000

# ============================================================================
# Memory System
# ============================================================================
ENABLE_MEMORY_EXTRACTION=True
ENABLE_SEMANTIC_SEARCH=True
ENABLE_USER_PROFILE_LEARNING=True
ENABLE_LONG_TERM_MEMORY=True

# Memory Extraction
MEMORY_EXTRACTION_INTERVAL=5
MEMORY_MIN_CONFIDENCE=0.6
MEMORY_MAX_CONVERSATIONS=100
MEMORY_EXTRACTION_MAX_RETRIES=2

# Vector Indexing
VECTOR_INDEXING_MAX_RETRIES=3
VECTOR_INDEXING_RETRY_DELAY=2.0

# User Profile
USER_PROFILE_UPDATE_INTERVAL=10

# Long-term Memory
LONG_TERM_MEMORY_MAX_ITEMS=50
LONG_TERM_MEMORY_PRUNE_THRESHOLD=0.3

# SQLite Database Storage
MEMORY_DB_PATH=data/memory.db
USE_SQLITE=True
DUAL_WRITE_MODE=False

# Markdown File Control
MD_USER_MAX_ITEMS=30
MD_MEMORY_MAX_ITEMS=50
MD_USER_INCLUDE_DAYS=30
MD_MEMORY_INCLUDE_DAYS=90
MD_SYNC_INTERVAL=10
MD_MIN_CONFIDENCE=0.7
MD_AUTO_SYNC=True

# ============================================================================
# Skills Dependency Management
# ============================================================================
ENABLE_SKILL_DEPENDENCY_CHECK=True
AUTO_INSTALL_PYTHON_DEPENDENCIES=True
SKILL_DEPENDENCY_INSTALL_TIMEOUT=300

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_TO_FILE=True
LOG_TO_CONSOLE=True
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
DEBUG_AGENT=True

# ========== Logging System Enhancement ==========

# Structured Logging
ENABLE_JSON_LOGS=False
JSON_LOG_FILE=backend.json.log

# Agent Execution Trajectory
ENABLE_AGENT_TRAJECTORY=True
TRAJECTORY_LOG_DIR=logs/trajectories
SAVE_TRAJECTORY_TO_FILE=True
MAX_TRAJECTORY_SIZE=10000

# ========== LangChain Callback Configuration ==========
# LangChain callback handler for trajectory capture
ENABLE_LANGCHAIN_CALLBACKS=True
CALLBACK_CAPTURE_THOUGHTS=True
CALLBACK_CAPTURE_ACTIONS=True
CALLBACK_CAPTURE_RESULTS=True

# Sensitive Information Sanitization
ENABLE_LOG_SANITIZATION=True
SANITIZE_USER_INPUT=False
SANITIZE_FILE_PATHS=True

# Error Tracking
ENABLE_ERROR_CONTEXT=True
CAPTURE_LOCALS_IN_ERRORS=False
MAX_LOCAL_VARS_TO_CAPTURE=10

# Business Metrics
ENABLE_BUSINESS_METRICS=True
METRICS_LOG_FILE=metrics.log
METRICS_AGGREGATION_INTERVAL=60

# Error Aggregation and Alerting
ENABLE_ERROR_AGGREGATION=True
ERROR_ALERT_THRESHOLD=10
ERROR_ALERT_WINDOW=60
